# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=localhost:3210

# Feature flags / local development
NEXT_PUBLIC_ENABLE_ARCHITECT_BRAINSTORM=false
E2E_AUTH_BYPASS=false
NEXT_PUBLIC_E2E_AUTH_BYPASS=false
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Provider auth (optional, enable only the providers you use)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

TOGETHER_API_KEY=
TOGETHER_DEFAULT_MODEL=togethercomputer/llama-3.1-70b

ZAI_API_KEY=
ZAI_CODING_PLAN_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_DEFAULT_MODEL=glm-4.7

CHUTES_API_KEY=
CHUTES_BASE_URL=https://llm.chutes.ai/v1
CHUTES_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
CHUTES_CLIENT_ID=
CHUTES_CLIENT_SECRET=
NEXT_PUBLIC_CHUTES_CLIENT_ID=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_DEFAULT_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
